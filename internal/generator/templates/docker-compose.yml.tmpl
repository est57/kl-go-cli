version: "3.8"
services:
  {{.PackageName}}:
    build:
      context: .
      dockerfile: deployments/Dockerfile
    ports:
{{if .HasHTTP}}
      - "{{.Port}}:{{.Port}}"
{{end}}
{{if .HasGRPC}}
      - "{{.GRPCPort}}:{{.GRPCPort}}"
{{end}}
    environment:
{{if .HasHTTP}}
      - PORT={{.Port}}
{{end}}
{{if .HasGRPC}}
      - GRPC_PORT={{.GRPCPort}}
{{end}}
      - APP_ENV=development
{{if .HasPostgres}}
      - DATABASE_URL=postgres://postgres:postgres@db:5432/{{.PackageName}}?sslmode=disable
    depends_on:
      db:
        condition: service_healthy
{{end}}

{{if .HasPostgres}}
  db:
    image: postgres:16-alpine
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB={{.PackageName}}
    ports:
      - "5432:5432"
    volumes:
      - {{.PackageName}}_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{.PackageName}}"]
      interval: 5s
      timeout: 3s
      retries: 10

volumes:
  {{.PackageName}}_pgdata:
{{end}}
