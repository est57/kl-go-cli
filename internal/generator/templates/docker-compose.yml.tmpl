version: "3.8"
services:
  {{.PackageName}}:
    build:
      context: .
      dockerfile: deployments/Dockerfile
    ports:
      - "{{.Port}}:{{.Port}}"
    environment:
      - PORT={{.Port}}
      - APP_ENV=development
      - DATABASE_URL=postgres://postgres:postgres@db:5432/{{.PackageName}}?sslmode=disable
    depends_on:
      - db

  db:
    image: postgres:16-alpine
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB={{.PackageName}}
    ports:
      - "5432:5432"
    volumes:
      - {{.PackageName}}_pgdata:/var/lib/postgresql/data

volumes:
  {{.PackageName}}_pgdata:
