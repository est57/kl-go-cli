package config

import "os"

type Config struct {
	Port        string
	Env         string
{{if .HasPostgres}}
	DatabaseURL string
{{end}}
	ServiceName string
}

func Load() *Config {
	return &Config{
		Port:        getEnv("PORT", "{{.Port}}"),
		Env:         getEnv("APP_ENV", "development"),
{{if .HasPostgres}}
		DatabaseURL: getEnv("DATABASE_URL", "postgres://postgres:postgres@localhost:5432/{{.PackageName}}?sslmode=disable"),
{{end}}
		ServiceName: "{{.ServiceName}}",
	}
}

func getEnv(key, fallback string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return fallback
}
